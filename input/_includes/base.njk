{# File: _includes/base.njk #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    {# Dynamically set the page title. 'title' comes from the front matter of each page. #}
    <title>{{ title | default("My site") }}</title>

    
    {# Link to your main CSS file. Make sure this path is correct based on your project structure #}
    {# and how you've set up passthrough copy in .eleventy.js #}
    <link rel="stylesheet" href="/css/style.css"> 
    
    {# You can add other common head elements here: meta descriptions, favicons, etc. #}
</head>
<body>

    <header>
        <h1>My Website</h1>
        <nav>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/about/">About</a></li>
                {# Add more navigation links here as your site grows #}
            </ul>
        </nav>
    </header>

    <main>
        {# This is where the content from your .md or .html files will be injected. #}
        {# The 'safe' filter is important to render HTML content correctly. #}
        {{ content | safe }}
    </main>

    <footer>
        {# Assuming you have the 'year' shortcode set up in your .eleventy.js #}
        <p>&copy; {% year %} Jacen Li. All rights reserved.</p>
        {# You could also use global data here, e.g., {{ comp.name }} if you set it up #}
    </footer>

    {# You can add JavaScript file links here, usually before the closing </body> tag #}
    {# <script src="/js/main.js"></script> #}

</body>
</html>