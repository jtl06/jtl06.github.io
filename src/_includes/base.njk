<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{{ title }}</title>
    <link rel="stylesheet" href="/styles/main.css?v=20260514a" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <div class="brand-group">
          <a class="brand" href="/">Jacen Li</a>
          <div class="social-links">
            <a href="https://www.linkedin.com/in/jacen-li/" target="_blank" rel="noreferrer">LinkedIn</a>
            <span aria-hidden="true">·</span>
            <a href="https://github.com/jtl06" target="_blank" rel="noreferrer">GitHub</a>
          </div>
        </div>
        <nav class="site-nav">
          <a{% if nav == "home" %} class="active" aria-current="page"{% endif %} href="/">Home</a>
          <a{% if nav == "projects" %} class="active" aria-current="page"{% endif %} href="/projects/">Projects</a>
          <a{% if nav == "open-source" %} class="active" aria-current="page"{% endif %} href="/open-source/">Open Source</a>
          <a{% if nav == "keyboards" %} class="active" aria-current="page"{% endif %} href="/keyboards/">Keyboards</a>
          <a{% if nav == "about" %} class="active" aria-current="page"{% endif %} href="/about/">About</a>
          <a{% if nav == "resume" %} class="active" aria-current="page"{% endif %} href="/resume/">Resume</a>
        </nav>
      </div>
    </header>
    <main>
      {{ content | safe }}
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <span>© <span id="current-year"></span> Jacen Li. All rights reserved.</span>
        <div class="site-footer__links">
          <a href="mailto:jacenli@icloud.com">jacenli@icloud.com</a>
        </div>
      </div>
    </footer>
    <script>
      const yearTarget = document.getElementById("current-year");
      if (yearTarget) {
        yearTarget.textContent = new Date().getFullYear();
      }
    </script>
  </body>
</html>
